{% extends 'base.html.twig' %}
{% block title %}Password Reset Email Sent — SymPET{% endblock %}
{% block body %}
<div class="card mx-auto" style="max-width: 700px;"><div class="card-body p-5 text-center">
    <div class="display-5 mb-3">📧</div>
    <h1 class="h2 fw-bold">Check your email</h1>
    <p class="text-muted">If an account matching your email exists, an email was just sent with a password reset link.</p>
    <p class="small text-muted">This link will expire in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.</p>
    <a href="{{ path('app_forgot_password_request') }}" class="btn btn-outline-primary">Try again</a>
</div></div>
{% endblock %}
