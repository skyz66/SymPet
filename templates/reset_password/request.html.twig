{% extends 'base.html.twig' %}
{% form_theme requestForm 'bootstrap_5_layout.html.twig' %}
{% block title %}Reset your password — SymPET{% endblock %}
{% block body %}
<div class="auth-shell row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card auth-card">
            <div class="card-body p-4 p-lg-5">
                <div class="auth-icon mx-auto mb-3"><i class="fa-solid fa-key"></i></div>
                <h1 class="h3 fw-bold text-center mb-2">Reset your password</h1>
                <p class="text-muted text-center">Enter your email and we will send you a secure reset link.</p>
                {{ form_start(requestForm, {'attr': {'class': 'sympet-form'}}) }}
                    {{ form_row(requestForm.email) }}
                    <button class="btn btn-primary btn-lg w-100 mt-2">Send password reset email</button>
                {{ form_end(requestForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
