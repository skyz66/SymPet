{% extends 'base.html.twig' %}
{% form_theme resetForm 'bootstrap_5_layout.html.twig' %}
{% block title %}Choose a new password — SymPET{% endblock %}
{% block body %}
<div class="auth-shell row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card auth-card">
            <div class="card-body p-4 p-lg-5">
                <div class="auth-icon mx-auto mb-3"><i class="fa-solid fa-key"></i></div>
                <h1 class="h3 fw-bold text-center mb-2">Choose a new password</h1>
                <p class="text-muted text-center">Create a strong new password for your SymPET account.</p>
                {{ form_start(resetForm, {'attr': {'class': 'sympet-form'}}) }}
                    {{ form_row(resetForm.plainPassword) }}
                    <button class="btn btn-primary btn-lg w-100 mt-2">Reset password</button>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
