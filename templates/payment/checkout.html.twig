{% extends 'base.html.twig' %}
{% block title %}Payment — SymPET{% endblock %}

{% block body %}
<div class="page-hero mb-4">
    <div class="eyebrow">Secure checkout</div>
    <h1 class="display-6 fw-bold mb-0">Complete your order</h1>
</div>
<div class="row g-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body p-4">
                <h2 class="h4 fw-bold mb-3">Payment details</h2>
                <div id="payment-element"></div>
                <button id="submit-btn" class="btn btn-primary btn-lg mt-4 w-100">Pay {{ total|number_format(2) }} €</button>
                <div id="error-msg" class="text-danger mt-3"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header fw-bold">Order Summary</div>
            <div class="card-body p-4">
                {% for item in items %}
                    <div class="d-flex justify-content-between gap-3 mb-3">
                        <span>{{ item.product.name }} × {{ item.qty }}</span>
                        <strong>{{ item.subtotal|number_format(2) }} €</strong>
                    </div>
                {% endfor %}
                <hr>
                <div class="d-flex justify-content-between fw-bold fs-4"><span>Total</span><span class="text-brand">{{ total|number_format(2) }} €</span></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://js.stripe.com/v3/"></script>
<script>
const stripe = Stripe('{{ stripePublicKey }}');
let elements;

fetch('{{ path('payment_intent') }}', {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
})
.then(r => r.json())
.then(data => {
    elements = stripe.elements({ clientSecret: data.clientSecret });
    elements.create('payment').mount('#payment-element');
});

document.getElementById('submit-btn').addEventListener('click', async () => {
    const { error } = await stripe.confirmPayment({
        elements,
        confirmParams: { return_url: '{{ absolute_url(path('payment_success')) }}' }
    });
    if (error) { document.getElementById('error-msg').textContent = error.message; }
});
</script>
{% endblock %}
