{% extends 'base.html.twig' %}
{% block title %}Payment — SymPET{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-7">
        <h3>Payment</h3>
        <div id="payment-element"></div>
        <button id="submit-btn" class="btn btn-success mt-3 w-100">
            Pay {{ total|number_format(2) }} €
        </button>
        <div id="error-msg" class="text-danger mt-2"></div>
    </div>
    <div class="col-md-5">
        <h5>Order Summary</h5>
        <hr>
        {% for item in items %}
        <div class="d-flex justify-content-between mb-2">
            <span>{{ item.product.name }} × {{ item.qty }}</span>
            <span>{{ item.subtotal|number_format(2) }} €</span>
        </div>
        {% endfor %}
        <hr>
        <div class="d-flex justify-content-between fw-bold">
            <span>Total</span>
            <span>{{ total|number_format(2) }} €</span>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://js.stripe.com/v3/"></script>
<script>
const stripe = Stripe('{{ stripePublicKey }}');
let elements;

fetch('{{ path('payment_intent') }}', {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
})
.then(r => r.json())
.then(data => {
    elements = stripe.elements({ clientSecret: data.clientSecret });
    elements.create('payment').mount('#payment-element');
});

document.getElementById('submit-btn').addEventListener('click', async () => {
    const { error } = await stripe.confirmPayment({
        elements,
        confirmParams: {
            return_url: '{{ absolute_url(path('payment_success')) }}'
        }
    });
    if (error) {
        document.getElementById('error-msg').textContent = error.message;
    }
});
</script>
{% endblock %}