{% extends 'base.html.twig' %}
{% block title %}Order Confirmed — SymPET{% endblock %}

{% block body %}
<div class="text-center mt-5">
    <h1 class="text-success">🎉 Order Confirmed!</h1>
    <p class="fs-5">Thank you for your purchase.</p>
    <p>Order number: <strong>#{{ order.id }}</strong></p>
    <p>Total: <strong>{{ order.total }} €</strong></p>
    <p>A confirmation email has been sent to <strong>{{ order.user.email }}</strong></p>
    <a href="{{ path('product_index') }}" class="btn btn-primary mt-3">
        Continue Shopping
    </a>
</div>
{% endblock %}