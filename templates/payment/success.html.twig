{% extends 'base.html.twig' %}
{% block title %}Order Confirmed — SymPET{% endblock %}

{% block body %}
<div class="card text-center mx-auto" style="max-width: 680px;">
    <div class="card-body p-5">
        <div class="display-4 mb-3">🎉</div>
        <h1 class="fw-bold text-success">Order Confirmed!</h1>
        <p class="fs-5 text-muted">Thank you for your purchase. We are preparing your pet accessories.</p>
        <div class="bg-light rounded-4 p-3 my-4 text-start">
            <p class="mb-2">Order number: <strong>#{{ order.id }}</strong></p>
            <p class="mb-2">Total: <strong>{{ order.total }} €</strong></p>
            <p class="mb-0">Confirmation sent to: <strong>{{ order.user.email }}</strong></p>
        </div>
        <a href="{{ path('product_index') }}" class="btn btn-primary">Continue Shopping</a>
    </div>
</div>
{% endblock %}
