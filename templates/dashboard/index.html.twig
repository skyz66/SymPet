{% extends 'base.html.twig' %}
{% block title %}Dashboard — SymPET{% endblock %}
{% block body %}
<div class="page-hero text-center">
    <div class="eyebrow">Welcome</div>
    <h1 class="display-6 fw-bold">Hello {{ controller_name }}!</h1>
    <p class="text-muted mb-4">Manage your SymPET experience from here.</p>
