{% extends 'base.html.twig' %}
{% block title %}Orders — Admin{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Orders</h2>
        <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">← Dashboard</a>
    </div>

    {# Pending Orders #}
    <h4 class="text-warning">⏳ Pending ({{ pending|length }})</h4>
    {% include 'admin/order/_table.html.twig' with {orders: pending, status: 'pending'} %}

    {# Paid Orders #}
    <h4 class="text-success mt-4">✅ Paid ({{ paid|length }})</h4>
    {% include 'admin/order/_table.html.twig' with {orders: paid, status: 'paid'} %}

    {# Shipped Orders #}
    <h4 class="text-info mt-4">🚚 Shipped ({{ shipped|length }})</h4>
    {% include 'admin/order/_table.html.twig' with {orders: shipped, status: 'shipped'} %}
</div>
{% endblock %}