{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard — SymPET{% endblock %}

{% block body %}
<div class="admin-shell">
    <div class="page-hero mb-4 d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div><div class="eyebrow">Admin area</div><h1 class="display-6 fw-bold mb-2">Dashboard</h1><p class="text-muted mb-0">Track sales, customers, orders, and product performance from one clean workspace.</p></div>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_admin_product_index') }}" class="btn btn-outline-primary">Products</a>
            <a href="{{ path('app_admin_category_index') }}" class="btn btn-outline-primary">Categories</a>
            <a href="{{ path('admin_user_index') }}" class="btn btn-outline-primary">Users</a>
            <a href="{{ path('admin_order_index') }}" class="btn btn-primary">Orders</a>
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><p class="text-muted mb-1">Total Revenue</p><h3 class="fw-bold mb-0 text-brand">{{ totalRevenue|number_format(2) }} €</h3></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><p class="text-muted mb-1">Total Clients</p><h3 class="fw-bold mb-0">{{ totalClients }}</h3></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><p class="text-muted mb-1">Pending Orders</p><h3 class="fw-bold mb-0 text-warning">{{ pendingOrders }}</h3></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><p class="text-muted mb-1">Paid Orders</p><h3 class="fw-bold mb-0 text-success">{{ paidOrders }}</h3></div></div></div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-lg-8"><div class="card h-100"><div class="card-header fw-bold">Revenue by Month (€)</div><div class="card-body"><canvas id="revenueChart" height="100"></canvas></div></div></div>
        <div class="col-lg-4"><div class="card h-100"><div class="card-header fw-bold">Top Selling Products</div><div class="card-body"><canvas id="topProductsChart"></canvas></div></div></div>
    </div>
    <div class="card"><div class="card-header fw-bold">Orders per Month</div><div class="card-body"><canvas id="ordersChart" height="80"></canvas></div></div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
new Chart(document.getElementById('revenueChart'), { type: 'line', data: { labels: {{ revenueLabels|json_encode|raw }}, datasets: [{ label: 'Revenue (€)', data: {{ revenueData|json_encode|raw }}, borderColor: '#1f8a70', backgroundColor: 'rgba(31,138,112,.12)', fill: true, tension: 0.4 }] } });
new Chart(document.getElementById('topProductsChart'), { type: 'doughnut', data: { labels: {{ topProductNames|json_encode|raw }}, datasets: [{ data: {{ topProductSales|json_encode|raw }}, backgroundColor: ['#1f8a70','#f59f45','#7fb069','#d97c20','#6ab7b8'] }] } });
new Chart(document.getElementById('ordersChart'), { type: 'bar', data: { labels: {{ orderLabels|json_encode|raw }}, datasets: [{ label: 'Number of Orders', data: {{ orderData|json_encode|raw }}, backgroundColor: '#f59f45' }] } });
</script>
{% endblock %}
