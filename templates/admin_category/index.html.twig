{% extends 'base.html.twig' %}
{% block title %}Categories — Admin{% endblock %}
{% block body %}
<div class="admin-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div><div class="eyebrow">Catalog</div><h1 class="display-6 fw-bold mb-0">Categories</h1></div>
        <div class="d-flex gap-2"><a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">Dashboard</a><a href="{{ path('app_admin_category_new') }}" class="btn btn-primary">Create new</a></div>
    </div>
    <div class="card"><div class="table-responsive"><table class="table table-hover align-middle">
        <thead><tr><th>Id</th><th>Name</th><th>Slug</th><th>Description</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        {% for category in categories %}
            <tr><td>{{ category.id }}</td><td class="fw-bold">{{ category.name }}</td><td><span class="badge bg-light text-muted border">{{ category.slug }}</span></td><td>{{ category.description }}</td><td class="text-end"><a href="{{ path('app_admin_category_show', {'id': category.id}) }}" class="btn btn-sm btn-outline-primary">Show</a> <a href="{{ path('app_admin_category_edit', {'id': category.id}) }}" class="btn btn-sm btn-primary">Edit</a></td></tr>
        {% else %}
            <tr><td colspan="5"><div class="empty-state my-3">No categories found.</div></td></tr>
        {% endfor %}
        </tbody>
    </table></div></div>
</div>
{% endblock %}
