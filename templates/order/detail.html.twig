{% extends 'base.html.twig' %}
{% block title %}Order — SymPET{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div><div class="eyebrow">Order detail</div><h1 class="display-6 fw-bold mb-0">Order</h1></div>
    <a href="{{ path('order_history') }}" class="btn btn-outline-primary">← Back to Orders</a>
</div>
<div class="row g-4 mb-4">
    <div class="col-lg-6"><div class="card h-100"><div class="card-body p-4">
        <h2 class="h5 fw-bold">Order Info</h2>
        <p><strong>Date:</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>
        <p><strong>Status:</strong> {% if order.status == 'paid' %}<span class="badge bg-success">Paid</span>{% elseif order.status == 'pending' %}<span class="badge bg-warning">Pending</span>{% elseif order.status == 'shipped' %}<span class="badge bg-info">Shipped</span>{% else %}<span class="badge bg-danger">Cancelled</span>{% endif %}</p>
        <p class="mb-0"><strong>Total:</strong> <span class="text-brand fw-bold fs-4">{{ order.total }} TND</span></p>
    </div></div></div>
</div>
<div class="card"><div class="card-header fw-bold">Order Items</div><div class="table-responsive"><table class="table table-hover align-middle">
    <thead><tr><th>Product</th><th>Unit Price</th><th>Quantity</th><th>Subtotal</th></tr></thead>
    <tbody>{% for line in order.orderLines %}<tr><td class="fw-bold">{{ line.product.name }}</td><td>{{ line.unitPrice }} TND</td><td>{{ line.quantity }}</td><td class="fw-bold text-brand">{{ line.subtotal|number_format(2) }} TND</td></tr>{% endfor %}</tbody>
    <tfoot><tr><td colspan="3" class="text-end fw-bold">Total:</td><td class="fw-bold text-brand">{{ order.total }} TND</td></tr></tfoot>
</table></div></div>
{% endblock %}

