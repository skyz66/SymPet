{% extends 'base.html.twig' %}
{% block title %}Order #{{ order.id }} — SymPET{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2>📦 Order #{{ order.id }}</h2>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Order Info</h5>
                    <p><strong>Date:</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>
                    <p><strong>Status:</strong>
                        {% if order.status == 'paid' %}
                            <span class="badge bg-success">Paid</span>
                        {% elseif order.status == 'pending' %}
                            <span class="badge bg-warning">Pending</span>
                        {% elseif order.status == 'shipped' %}
                            <span class="badge bg-info">Shipped</span>
                        {% else %}
                            <span class="badge bg-danger">Cancelled</span>
                        {% endif %}
                    </p>
                    <p><strong>Total:</strong>
                        <span class="text-primary fw-bold">{{ order.total }} TND</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h5>Order Items</h5>
    <table class="table table-hover">
        <thead class="table-primary">
            <tr>
                <th>Product</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
        {% for line in order.orderLines %}
            <tr>
                <td>{{ line.product.name }}</td>
                <td>{{ line.unitPrice }} TND</td>
                <td>{{ line.quantity }}</td>
                <td class="fw-bold">{{ line.subtotal|number_format(2) }} TND</td>
            </tr>
        {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end fw-bold">Total:</td>
                <td class="fw-bold text-primary">{{ order.total }} TND</td>
            </tr>
        </tfoot>
    </table>

    <a href="{{ path('order_history') }}" class="btn btn-outline-secondary mt-3">
        ← Back to Orders
    </a>
</div>
{% endblock %}