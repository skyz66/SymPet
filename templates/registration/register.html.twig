{% extends 'base.html.twig' %}
{% form_theme registrationForm 'bootstrap_5_layout.html.twig' %}
{% block title %}Register — SymPET{% endblock %}
{% block body %}
<div class="auth-shell row justify-content-center">
    <div class="col-12 col-md-9 col-lg-7 col-xl-6">
        <div class="card auth-card">
            <div class="card-body p-4 p-lg-5">
                <div class="text-center mb-4">
                    <div class="auth-icon mx-auto mb-3"><i class="fa-solid fa-paw"></i></div>
                    <div class="eyebrow">Create account</div>
                    <h1 class="h2 fw-bold mb-2">Join SymPET</h1>
                    <p class="text-muted mb-0">Create an account to order faster and track your purchases.</p>
                </div>

                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="alert alert-danger rounded-4">{{ flash_error }}</div>
                {% endfor %}

                {{ form_errors(registrationForm) }}
                {{ form_start(registrationForm, {'attr': {'class': 'sympet-form'}}) }}
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(registrationForm.firstName) }}</div>
                        <div class="col-md-6">{{ form_row(registrationForm.lastName) }}</div>
                    </div>
                    {{ form_row(registrationForm.email) }}
                    {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}
                    <div class="terms-box mb-3">
                        {{ form_row(registrationForm.agreeTerms) }}
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Register</button>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
