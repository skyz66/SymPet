<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}SymPET{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
        <style>
            :root {
                --sympet-cream: #fff8ed; --sympet-soft: #f8ead7; --sympet-orange: #f59f45;
                --sympet-orange-dark: #d97c20; --sympet-teal: #1f8a70; --sympet-dark: #24332f;
                --sympet-muted: #6f7c78; --sympet-border: rgba(36, 51, 47, .10);
                --sympet-shadow: 0 18px 45px rgba(36, 51, 47, .10); --sympet-radius: 1.25rem;
            }
            body { min-height: 100vh; display: flex; flex-direction: column; color: var(--sympet-dark); background: radial-gradient(circle at top left, rgba(245,159,69,.16), transparent 32rem), linear-gradient(180deg, #fffaf2 0%, #fff 45%, #fff8ed 100%); }
            body.no-scroll-page { height: 100vh; overflow: hidden; }
            body.no-scroll-page .site-main { overflow: hidden; }
            body.no-scroll-page footer { display: none; }
            a { color: var(--sympet-teal); } a:hover { color: var(--sympet-orange-dark); }
            .navbar-sympet { background: rgba(255,248,237,.92); backdrop-filter: blur(14px); border-bottom: 1px solid var(--sympet-border); }
            .navbar-brand { color: var(--sympet-dark) !important; letter-spacing: -.02em; }
            .nav-link { color: var(--sympet-dark) !important; font-weight: 600; } .nav-link:hover { color: var(--sympet-orange-dark) !important; }
            .btn { border-radius: 999px; font-weight: 700; padding: .65rem 1rem; }
            .btn-primary, .btn-success { background: var(--sympet-teal); border-color: var(--sympet-teal); color: #fff; }
            .btn-primary:hover, .btn-success:hover { background: #176b58; border-color: #176b58; }
            .btn-outline-primary { color: var(--sympet-teal); border-color: var(--sympet-teal); }
            .btn-outline-primary:hover { background: var(--sympet-teal); border-color: var(--sympet-teal); }
            .btn-warning { background: var(--sympet-orange); border-color: var(--sympet-orange); color: #2b2118; }
            .card, .sympet-card { border: 1px solid var(--sympet-border); border-radius: var(--sympet-radius); box-shadow: var(--sympet-shadow); overflow: hidden; background: rgba(255,255,255,.92); }
            .card-header { background: #fff9f0; border-bottom: 1px solid var(--sympet-border); }
            .table { margin-bottom: 0; } .table thead th { color: var(--sympet-muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid var(--sympet-border); }
            .table td, .table th { vertical-align: middle; }
            .form-control, .form-select { border-radius: .9rem; padding: .75rem .9rem; border-color: var(--sympet-border); }
            .form-control:focus, .form-select:focus { border-color: var(--sympet-orange); box-shadow: 0 0 0 .25rem rgba(245,159,69,.18); }
            .badge { border-radius: 999px; padding: .5rem .7rem; }
            .page-hero { border-radius: 1.75rem; padding: clamp(1.4rem,4vw,3rem); background: linear-gradient(135deg, #fff4df 0%, #effaf6 100%); border: 1px solid var(--sympet-border); box-shadow: var(--sympet-shadow); }
            .eyebrow { color: var(--sympet-orange-dark); font-weight: 800; text-transform: uppercase; letter-spacing: .08em; font-size: .78rem; }
            .text-brand { color: var(--sympet-teal) !important; } .text-muted { color: var(--sympet-muted) !important; }
            .product-card { transition: transform .2s ease, box-shadow .2s ease; } .product-card:hover { transform: translateY(-4px); box-shadow: 0 24px 55px rgba(36,51,47,.14); }
            .product-img { height: 220px; object-fit: cover; background: var(--sympet-soft); }
            .admin-shell .card { box-shadow: 0 12px 32px rgba(36,51,47,.08); }
            .empty-state { border: 1px dashed rgba(31,138,112,.35); background: rgba(31,138,112,.06); border-radius: var(--sympet-radius); padding: 2rem; text-align: center; }
            .site-main { flex: 1; }
            .site-main.site-main-wide { max-width: min(1760px, calc(100vw - 2rem)); }
            footer { border-top: 1px solid var(--sympet-border); background: rgba(255,248,237,.86); }

            .auth-shell { min-height: calc(100vh - 260px); align-items: center; }
            .auth-card { max-width: 100%; }
            .auth-icon { width: 3.2rem; height: 3.2rem; border-radius: 999px; display: grid; place-items: center; background: rgba(31,138,112,.10); color: var(--sympet-teal); font-size: 1.35rem; }
            .sympet-form .form-label, form label { font-weight: 700; color: var(--sympet-dark); margin-bottom: .45rem; }
            .sympet-form .mb-3 { margin-bottom: 1rem !important; }
            .sympet-form .form-control, .sympet-form .form-select, form input:not([type='checkbox']):not([type='radio']):not([type='hidden']), form select, form textarea { display: block; width: 100%; border-radius: .9rem; padding: .75rem .9rem; border: 1px solid var(--sympet-border); background-color: #fff; }
            .sympet-form .form-control:focus, .sympet-form .form-select:focus, form input:not([type='checkbox']):not([type='radio']):focus, form select:focus, form textarea:focus { border-color: var(--sympet-orange); box-shadow: 0 0 0 .25rem rgba(245,159,69,.18); outline: 0; }
            .form-check { display: flex; align-items: center; gap: .55rem; padding-left: 0; }
            .form-check .form-check-input, form input[type='checkbox'] { width: 1.05rem; height: 1.05rem; margin: 0; flex: 0 0 auto; }
            .form-check .form-check-label, .terms-box label { margin: 0; font-weight: 600; color: var(--sympet-muted); }
            .terms-box { padding: .9rem 1rem; border-radius: 1rem; background: #fff9f0; border: 1px solid var(--sympet-border); }
            .terms-box .mb-3 { margin-bottom: 0 !important; }
            @media (min-width: 1600px) { .site-main.site-main-wide { max-width: min(1880px, calc(100vw - 3rem)); } }
            @media (max-width: 767.98px) { .product-img { height: 190px; } .table-responsive { border-radius: var(--sympet-radius); } }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    {% set currentRoute = app.request.attributes.get('_route') %}
    {% set noScrollRoutes = ['home', 'product_legacy_index', 'product_index'] %}
    <body class="{% if currentRoute in noScrollRoutes %}no-scroll-page{% endif %}">
        <nav class="navbar navbar-expand-lg navbar-light navbar-sympet sticky-top">
            <div class="container py-2">
                <a class="navbar-brand fw-bold fs-3" href="{{ path('product_index') }}">🐾 SymPET</a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#sympetNavbar" aria-controls="sympetNavbar" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                <div class="collapse navbar-collapse" id="sympetNavbar">
                    <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2 pt-3 pt-lg-0">
                        <a href="{{ path('product_index') }}" class="nav-link">Shop</a>
                        {% if is_granted('ROLE_USER') %}
                            <a href="{{ path('order_history') }}" class="nav-link">Orders</a>
                            <a href="{{ path('cart_index') }}" class="btn btn-outline-primary btn-sm my-1 my-lg-0"><i class="fa-solid fa-cart-shopping me-1"></i> Cart ({{ cart_count ?? 0 }})</a>
                            <a href="{{ path('app_logout') }}" class="nav-link">Logout</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm my-1 my-lg-0">Login</a>
                            <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm my-1 my-lg-0">Register</a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}" class="btn btn-warning btn-sm my-1 my-lg-0">Admin</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <main class="site-main container {% if currentRoute in noScrollRoutes %}site-main-wide py-3 py-lg-4{% else %}py-4 py-lg-5{% endif %}">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show rounded-4 shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>

        <footer class="py-4 mt-4">
            <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 small text-muted">
                <span class="fw-bold text-brand">🐾 SymPET</span>
                <span>Friendly accessories for happy pets.</span>
                <span>&copy; {{ "now"|date("Y") }} SymPET</span>
            </div>
        </footer>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
