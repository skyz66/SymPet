<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}SymPET
			{% endblock %}
		</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
		<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"> {% block stylesheets %}{% endblock %}
		</head>
		<body>

			<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
				<div class="container">
					<a class="navbar-brand fw-bold" href="{{ path('product_index') }}">🐾 SymPET</a>
					<div class="navbar-nav ms-auto d-flex flex-row gap-3 align-items-center">
						<a href="{{ path('product_index') }}" class="nav-link text-white">Shop</a>
						{% if is_granted('ROLE_USER') %}
							<a href="{{ path('cart_index') }}" class="nav-link text-white">
								🛒 Cart ({{ cart_count ?? 0 }})
							</a>
							<a href="{{ path('app_logout') }}" class="nav-link text-white">Logout</a>
						{% else %}
							<a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm">Login</a>
							<a href="{{ path('app_register') }}" class="btn btn-light btn-sm">Register</a>
						{% endif %}
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('admin_dashboard') }}" class="btn btn-warning btn-sm">
								Admin
							</a>
						{% endif %}
					</div>
				</div>
			</nav>

			<main class="container my-4">
				{% for label, messages in app.flashes %}
					{% for message in messages %}
						<div class="alert alert-{{ label }}">{{ message }}</div>
					{% endfor %}
				{% endfor %}
				{% block body %}{% endblock %}
			</main>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
			{% block javascripts %}{% endblock %}
		</body>
	</html>
