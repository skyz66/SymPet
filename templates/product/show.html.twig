{% extends 'base.html.twig' %}
{% block title %}
	{{ product.name }}
	— SymPET
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<div class="row">
			<div class="col-md-5">
				<img src="{{ product.imagePath }}" class="img-fluid rounded shadow" alt="{{ product.name }}">
			</div>
			<div class="col-md-7">
				<h2>{{ product.name }}</h2>
				<p class="text-muted">{{ product.category.name }}</p>
				<h3 class="text-primary">{{ product.price }}
					TND</h3>
				<p>{{ product.description }}</p>
				<p>
					{% if product.stock > 0 %}
						<span class="badge bg-success">In stock:
							{{ product.stock }}</span>
					{% else %}
						<span class="badge bg-danger">Out of stock</span>
					{% endif %}
				</p>
				<a href="{{ path('cart_add', {id: product.id}) }}" class="btn btn-primary flex-fill">Add to Cart</a>
				<a href="{{ path('product_index') }}" class="btn btn-outline-secondary btn-lg">Back to Shop</a>
			</div>
		</div>
	</div>
{% endblock %}
