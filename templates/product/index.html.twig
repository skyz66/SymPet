{% extends 'base.html.twig' %}

{% block title %}Shop — SymPET{% endblock %}

{% block stylesheets %}
<style>
    .catalog-layout {
        height: auto;
    }

    .filter-card {
        position: sticky;
        top: 5.5rem;
    }

    .filter-card .card-body {
        overflow: visible;
    }

    .filter-form {
        display: flex;
        flex-direction: column;
    }

    .filter-actions {
        margin-top: auto;
        padding-top: .25rem;
    }

    .products-column {
        display: flex;
        flex-direction: column;
    }

    .products-scroll {
        height: auto;
        max-height: none;
        overflow: visible;
        padding-right: 0;
    }

    .products-pagination {
        position: static;
        background: transparent;
        padding-top: .5rem;
        margin-top: 0rem;
        margin-bottom: 2.5rem;
    }

    .product-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .product-card {
        cursor: pointer;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 1rem 2.5rem rgba(31, 138, 112, .18);
    }

    .product-card:hover .product-title {
        color: var(--sympet-teal);
    }

    .pagination {
        margin-bottom: 0;
    }

    .pagination .page-link {
        color: var(--sympet-teal);
        border-radius: .75rem;
        margin: 0 .15rem;
        padding: .55rem .85rem;
    }

    .pagination .page-item.active .page-link {
        background: var(--sympet-teal);
        border-color: var(--sympet-teal);
        color: #fff;
    }

    @media (min-width: 1600px) {
        .product-grid {
            --bs-gutter-x: 1.8rem;
        }
    }

    @media (max-width: 991.98px) {
        .catalog-layout {
            height: auto;
        }

        .filter-card {
            position: static;
            min-height: 0;
            max-height: none;
            height: auto;
        }

        .products-scroll {
            overflow: visible;
            padding-right: 0;
        }

        .products-pagination {
            position: static;
            background: transparent;
            padding-top: 1rem;
            margin-top: 1.5rem;
            margin-bottom: 2rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="row g-3 g-xxl-4 catalog-layout">
    <div class="col-lg-3 col-xxl-2">
        <div class="card filter-card">
            <div class="card-header fw-bold">
                <i class="fa-solid fa-filter me-2 text-brand"></i>
                Filters
            </div>

            <div class="card-body">
                <form method="GET" class="filter-form">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Search</label>
                        <input 
                            type="text" 
                            name="q" 
                            value="{{ query }}" 
                            class="form-control" 
                            placeholder="Search accessories..."
                        >
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Category</label>
                        <select id="category-filter" name="category" class="form-select">
                            <option value="">All categories</option>

                            {% for cat in categories %}
                                <option value="{{ cat.id }}" {% if selectedCat == cat.id %}selected{% endif %}>
                                    {{ cat.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Animal Type</label>
                        <select id="animal-filter" name="animal" class="form-select">
                            <option value="">All animals</option>
                            <option value="dog" {% if animalType == 'dog' %}selected{% endif %}>🐶 Dog</option>
                            <option value="cat" {% if animalType == 'cat' %}selected{% endif %}>🐱 Cat</option>
                            <option value="bird" {% if animalType == 'bird' %}selected{% endif %}>🐦 Bird</option>
                            <option value="fish" {% if animalType == 'fish' %}selected{% endif %}>🐠 Fish</option>
                            <option value="rabbit" {% if animalType == 'rabbit' %}selected{% endif %}>🐰 Rabbit</option>
                        </select>

                        <div id="animal-filter-hint" class="form-text d-none"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Price Range (TND)</label>

                        <div class="d-flex gap-2">
                            <input 
                                type="number" 
                                name="min_price" 
                                value="{{ minPrice }}" 
                                class="form-control" 
                                placeholder="Min" 
                                min="0"
                            >

                            <input 
                                type="number" 
                                name="max_price" 
                                value="{{ maxPrice }}" 
                                class="form-control" 
                                placeholder="Max" 
                                min="0"
                            >
                        </div>
                    </div>

                    <div class="filter-actions">
                        <button class="btn btn-primary w-100">
                            Apply Filters
                        </button>

                        <a href="{{ path('product_index') }}" class="btn btn-outline-secondary w-100 mt-2">
                            Clear Filters
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-9 col-xxl-10 products-column">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 fw-bold mb-0">
                Featured products
            </h2>

            <span class="text-muted small">
                {{ products.getTotalItemCount() }} results
            </span>
        </div>

        <div class="products-scroll">
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 row-cols-xxl-4 g-4 product-grid">
                {% for product in products %}
                    <div class="col">
                        <a href="{{ path('product_show', {id: product.id}) }}" class="product-card-link">
                            <div class="card h-100 product-card">
                                <img 
                                    src="{{ product.imagePath }}" 
                                    class="card-img-top product-img" 
                                    alt="{{ product.name }}"
                                >

                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between gap-2 mb-2">
                                        <span class="badge bg-light text-brand border">
                                            {{ product.category.name }}
                                        </span>

                                        {% if product.animalType %}
                                            <span class="badge bg-light text-muted border">
                                                {% if product.animalType == 'dog' %}
                                                    🐶
                                                {% elseif product.animalType == 'cat' %}
                                                    🐱
                                                {% elseif product.animalType == 'bird' %}
                                                    🐦
                                                {% elseif product.animalType == 'fish' %}
                                                    🐠
                                                {% else %}
                                                    🐰
                                                {% endif %}

                                                {{ product.animalType|capitalize }}
                                            </span>
                                        {% endif %}
                                    </div>

                                    <h3 class="h5 fw-bold mb-2 product-title">
                                        {{ product.name }}
                                    </h3>

                                    <p class="text-brand fw-bold fs-5 mb-0 mt-auto">
                                        {{ product.price }} TND
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="empty-state">
                            <h3 class="h5">
                                No products found
                            </h3>

                            <p class="text-muted mb-3">
                                Try different filters or clear your search.
                            </p>

                            <a href="{{ path('product_index') }}" class="btn btn-primary">
                                Reset filters
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="d-flex justify-content-center products-pagination">
                {{ knp_pagination_render(products) }}
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const categoryFilter = document.getElementById('category-filter');
        const animalFilter = document.getElementById('animal-filter');
        const animalFilterHint = document.getElementById('animal-filter-hint');

        if (!categoryFilter || !animalFilter || !animalFilterHint) {
            return;
        }

        const categoryAnimalMap = {{ categoryAnimalMap|json_encode|raw }};

        const animalLabels = {
            dog: 'Dog',
            cat: 'Cat',
            bird: 'Bird',
            fish: 'Fish',
            rabbit: 'Rabbit'
        };

        const setAnimalFilterState = function () {
            const selectedCategory = categoryFilter.value;
            const enforcedAnimal = categoryAnimalMap[selectedCategory] || null;

            if (enforcedAnimal) {
                animalFilter.value = enforcedAnimal;
                animalFilter.setAttribute('disabled', 'disabled');

                animalFilterHint.classList.remove('d-none');
                animalFilterHint.textContent = 'Animal type is fixed to ' + animalLabels[enforcedAnimal] + ' for this category.';

                return;
            }

            animalFilter.removeAttribute('disabled');

            animalFilterHint.classList.add('d-none');
            animalFilterHint.textContent = '';
        };

        categoryFilter.addEventListener('change', setAnimalFilterState);

        setAnimalFilterState();
    })();
</script>
{% endblock %}